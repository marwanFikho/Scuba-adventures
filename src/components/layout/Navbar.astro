---
import MenuIcon from '../icons/Menu.astro';
import GlobeIcon from '../icons/Globe.astro';
import ChevronDownIcon from '../icons/ChevronDown.astro';
import { getLangFromPathname, switchLanguagePath } from '../../lib/i18n';
import { getTranslations } from '../../lib/i18n';
import { BRAND_NAME } from '../../lib/brand';

const user = Astro.locals.user ?? null;
const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);
const basePath = `/${lang}`;
const pathname = Astro.url.pathname;

const navLinks = [
	{ href: `${basePath}/`, text: t.nav.home },
	{ href: `${basePath}/contact`, text: t.nav.contact }
];

const divingLinks = [
	{ href: `${basePath}/discover-diving`, text: t.nav.discoverDiving },
	{ href: `${basePath}/daily-dive`, text: t.nav.dailyDive },
	{ href: `${basePath}/courses`, text: t.nav.courses },
	{ href: `${basePath}/specialties`, text: t.nav.specialties },
	{ href: `${basePath}/one-week-adventure`, text: t.nav.adventure }
];

const langOptions = [
	{ code: 'en', label: t.common.english },
] as const;

const accountHref = user ? `${basePath}/dashboard` : `${basePath}/signin`;
const accountLabel = user ? t.nav.dashboard : t.nav.signIn;
---
<header id="main-header" class="relative top-0 left-0 w-full z-50 bg-zinc-800 backdrop-blur-md shadow-md border-b border-ocean-muted/20">
  
  <div class="p-2 flex items-center justify-between w-full">
    
    <a href={`/${lang}/`} class="flex items-center gap-2 group">
      <img src="/mikasa.png?v=2" alt="Scuba Adventures Logo" class="h-14 w-auto" loading="eager" />
    </a>

    <div class="hidden md:block">
				<div class="ml-10 flex items-baseline space-x-1">
{navLinks.map((link) => (
            <a href={link.href} class="text-yellow-500 hover:text-yellow-300 px-3 py-2 rounded-md text-sm font-medium transition">
              {link.text}
            </a>
          ))}					<div class="relative" id="diving-dropdown">
						<button type="button" class="diving-dropdown-btn hover:text-yellow-500 hover:text-yellow-500! px-3 py-2 rounded-md text-sm font-medium transition-colors flex items-center gap-1" aria-haspopup="true" aria-expanded="false">
							<span data-i18n-key="nav.diving">{t.nav.diving}</span>
							<ChevronDownIcon class="w-4 h-4 diving-chevron transition-transform duration-200 hover:text-yellow-500" />
						</button>
						<div class="diving-dropdown-menu absolute left-0 mt-2 w-56 rounded-md shadow-premium bg-zinc-800  border-white/30 hidden overflow-hidden" role="menu">
							{divingLinks.map((link) => (
								<a href={link.href} class="block px-4 py-3 text-sm text-text-secondary hover:text-ocean-dark hover:bg-ocean-muted/10 transition-colors" role="menuitem">{link.text}</a>
							))}
						</div>
					</div>
				</div>
			</div>
			<div class="flex items-center gap-2 mr-2">

    <button
      type="button"
      data-theme-btn="dark"
      class="w-8 h-8 rounded-full bg-zinc-900 border border-zinc-600 hover:border-[#f2c94c]"
      title="Dark Mode"
    >
      🌙
    </button>

    <button
      type="button"
      data-theme-btn="light"
      class="w-8 h-8 rounded-full bg-white border border-zinc-300 hover:border-[#f2c94c]"
      title="Light Mode"
    >
      ☀️
    </button>

    <button
      type="button"
      data-theme-btn="extra-light"
      class="w-8 h-8 rounded-full bg-slate-50 border border-slate-200 hover:border-[#f2c94c]"
      title="Extra Light"
    >
      ✨
    </button>

  </div>
				<div class="relative" id="lang-menu-desktop">
					<button type="button" class="text-text-secondary hover:text-ocean-dark flex items-center gap-2 text-sm font-medium transition-colors" aria-haspopup="true" aria-expanded="false">
						<GlobeIcon />
						<span>{lang.toUpperCase()}</span>
					</button>
					<div class="absolute right-0 mt-2 w-36 rounded-md shadow-premium bg-white border border-ocean-muted/30 hidden" data-lang-panel>
						{langOptions.map((opt) => (
							<a href={switchLanguagePath(pathname, opt.code)} class="block px-4 py-2 text-sm text-text-secondary hover:text-ocean-dark hover:bg-ocean-muted/10">{opt.label}</a>
						))}
					</div>
				</div>
				<a href={accountHref} class="bg-yellow-500 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-ocean-muted transition-colors">{accountLabel}</a>
			</div>
			<div class="-mr-2 flex md:hidden">
				<button type="button" id="mobile-menu-button" class="inline-flex items-center justify-center p-2 rounded-md text-text-secondary hover:text-ocean-dark focus:outline-none transition-colors" aria-expanded="false">
					<MenuIcon />
				</button>
			</div>
		</div>
	</header>

	<div id="mobile-menu" class="md:hidden hidden border-t border-ocean-muted/20 bg-white max-h-[80vh] overflow-y-auto">
		<div class="px-4 pt-3 pb-4 space-y-1">
			<a href={`${basePath}/`} class="mobile-nav-link text-text-secondary hover:text-ocean-dark block px-3 py-3 rounded-lg text-base font-medium transition-colors" data-i18n-key="nav.home">{t.nav.home}</a>
			<div class="mobile-diving-section">
				<button type="button" id="mobile-diving-toggle" class="w-full text-left text-text-secondary hover:text-ocean-dark px-3 py-3 rounded-lg text-base font-medium flex items-center justify-between transition-colors">
					<span data-i18n-key="nav.diving">{t.nav.diving}</span>
					<ChevronDownIcon id="mobile-diving-chevron" class="w-5 h-5 transition-transform duration-200 text-ocean-muted" />
				</button>
				<div id="mobile-diving-links" class="hidden pl-4 space-y-1 mt-1">
					{divingLinks.map((link) => (
						<a href={link.href} class="mobile-nav-link text-text-secondary hover:text-ocean-dark block px-3 py-2.5 rounded-lg text-sm font-medium transition-colors">{link.text}</a>
					))}
				</div>
			</div>
			<a href={`${basePath}/contact`} class="mobile-nav-link text-text-secondary hover:text-ocean-dark block px-3 py-3 rounded-lg text-base font-medium transition-colors" data-i18n-key="nav.contact">{t.nav.contact}</a>
			<div class="border-t border-ocean-muted/20 my-3"></div>
			<a href={accountHref} class="bg-secondary text-white block text-center w-full px-4 py-3 rounded-lg text-base font-medium hover:bg-ocean-muted transition-colors">{accountLabel}</a>
			<div class="pt-3 border-t border-ocean-muted/20">
				<p class="text-xs text-ocean-dark uppercase tracking-wide mb-2 px-3 font-semibold" data-i18n-key="nav.language">{t.nav.language ?? 'Language'}</p>
				<div class="flex gap-2 px-3">
					{langOptions.map((opt) => (
						<a href={switchLanguagePath(pathname, opt.code)} class="flex-1 text-center text-text-secondary hover:text-ocean-dark hover:bg-ocean-muted/10 block px-3 py-2 rounded-lg text-sm font-medium transition-colors">{opt.label}</a>
					))}
				</div>
			</div>
		</div>
	</div>

<script>
	import { gsap } from 'gsap';

	const CLOSE_DELAY_MS = 400;

	const setupLangMenu = (rootId: string) => {
		const root = document.getElementById(rootId);
		if (!root) return;
		const panel = root.querySelector('[data-lang-panel]');
		const button = root.querySelector('button');
		if (!panel || !button) return;

		let closeTimer: ReturnType<typeof setTimeout> | null = null;

		const open = () => {
			if (closeTimer) clearTimeout(closeTimer);
			panel.classList.remove('hidden');
			button.setAttribute('aria-expanded', 'true');
		};

		const scheduleClose = () => {
			if (closeTimer) clearTimeout(closeTimer);
			closeTimer = setTimeout(() => {
				panel.classList.add('hidden');
				button.setAttribute('aria-expanded', 'false');
			}, CLOSE_DELAY_MS);
		};

		root.addEventListener('mouseenter', open);
		root.addEventListener('mouseleave', scheduleClose);
		panel.addEventListener('mouseenter', open);
		panel.addEventListener('mouseleave', scheduleClose);
	};

	setupLangMenu('lang-menu-desktop');

	const divingDropdown = document.getElementById('diving-dropdown');
	const divingBtn = divingDropdown?.querySelector('.diving-dropdown-btn');
	const divingMenu = divingDropdown?.querySelector('.diving-dropdown-menu');
	const divingChevron = divingDropdown?.querySelector('.diving-chevron');

	let divingOpen = false;
	let divingHoverTimer: ReturnType<typeof setTimeout> | null = null;

	const openDiving = () => {
		if (divingHoverTimer) clearTimeout(divingHoverTimer);
		if (!divingOpen) {
			divingOpen = true;
			divingMenu?.classList.remove('hidden');
			divingBtn?.setAttribute('aria-expanded', 'true');
			gsap.to(divingChevron!, { rotation: 180, duration: 0.2, ease: 'power2.out' });
			gsap.fromTo(divingMenu!, { opacity: 0, y: -10 }, { opacity: 1, y: 0, duration: 0.2, ease: 'power2.out' });
		}
	};

	const closeDiving = () => {
		divingHoverTimer = setTimeout(() => {
			divingOpen = false;
			divingMenu?.classList.add('hidden');
			divingBtn?.setAttribute('aria-expanded', 'false');
			gsap.to(divingChevron!, { rotation: 0, duration: 0.2, ease: 'power2.out' });
		}, CLOSE_DELAY_MS);
	};

	divingDropdown?.addEventListener('mouseenter', openDiving);
	divingDropdown?.addEventListener('mouseleave', closeDiving);
	divingBtn?.addEventListener('click', (e) => {
		e.preventDefault();
		if (divingOpen) {
			closeDiving();
		} else {
			openDiving();
		}
	});

	const mobileMenuButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');
	const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

	const closeMobileMenu = () => {
		mobileMenu?.classList.add('hidden');
	};

	mobileMenuButton?.addEventListener('click', () => {
		mobileMenu?.classList.toggle('hidden');
	});

	mobileNavLinks.forEach(link => {
		link.addEventListener('click', closeMobileMenu);
	});

	document.addEventListener('click', (e) => {
		if (mobileMenu && !mobileMenu.classList.contains('hidden') && 
		    !mobileMenu.contains(e.target as Node) && 
		    !mobileMenuButton?.contains(e.target as Node)) {
			closeMobileMenu();
		}
	});

	const mobileDivingToggle = document.getElementById('mobile-diving-toggle');
	const mobileDivingLinks = document.getElementById('mobile-diving-links');
	const mobileDivingChevron = document.getElementById('mobile-diving-chevron');
	let mobileDivingOpen = false;

	mobileDivingToggle?.addEventListener('click', () => {
		mobileDivingOpen = !mobileDivingOpen;
		if (mobileDivingOpen) {
			mobileDivingLinks?.classList.remove('hidden');
			gsap.to(mobileDivingChevron, { rotation: 180, duration: 0.2, ease: 'power2.out' });
		} else {
			mobileDivingLinks?.classList.add('hidden');
			gsap.to(mobileDivingChevron, { rotation: 0, duration: 0.2, ease: 'power2.out' });
		}
	});
document.querySelectorAll('[data-theme-btn]').forEach(btn => {
  btn.addEventListener('click', () => {
    const theme = btn.getAttribute('data-theme-btn');

    document.documentElement.setAttribute(
      'data-theme',
      theme ?? 'light'
    );

    localStorage.setItem('theme', theme?? 'light');
  });
});

const savedTheme = localStorage.getItem('theme');

if (savedTheme) {
  document.documentElement.setAttribute(
    'data-theme',
    savedTheme
  );
}
</script>
