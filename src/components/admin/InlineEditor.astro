---
export interface Props {
  lang: string;
  isAdmin: boolean;
}

const { lang, isAdmin } = Astro.props;

// Fetch overrides during SSR so they're in the HTML from the start — no flash
import { contentRepository } from '../../repositories/content.repository';
const overrides = await contentRepository.getOverrides(lang);
const overridesJson = JSON.stringify(overrides);
---

<script id="ie-data" type="application/json">{overridesJson}</script>

{isAdmin && (
  <div id="inline-editor-bar" class="fixed bottom-4 right-4 z-[9999] flex items-center gap-2">
    <button
      id="inline-editor-toggle"
      class="bg-ocean-dark text-white px-4 py-2 rounded-full shadow-lg text-sm font-medium hover:bg-ocean transition-all duration-200 flex items-center gap-2"
      title="Toggle edit mode"
    >
      <svg id="edit-icon-pencil" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
      <svg id="edit-icon-check" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
      <span id="edit-label">Edit</span>
    </button>
    <div id="edit-save-indicator" class="hidden bg-green-500 text-white px-3 py-2 rounded-full text-xs shadow-lg">Saved</div>
  </div>
)}

<style is:global>
  .ie-editing {
    outline: 2px dashed rgba(59, 130, 246, 0.5) !important;
    outline-offset: 1px !important;
    cursor: pointer !important;
    border-radius: 2px !important;
    transition: outline-color 0.15s;
  }
  .ie-editing:hover {
    outline-color: rgba(59, 130, 246, 0.9) !important;
  }
  .ie-editing-focus {
    outline: 2px solid #3b82f6 !important;
    outline-offset: 1px !important;
    border-radius: 2px !important;
  }
</style>

<!-- Edit modal -->
<dialog id="ie-modal" class="rounded-xl p-0 max-w-2xl w-[90vw] backdrop:bg-black/40 shadow-2xl border-0 overflow-hidden">
  <div class="p-4 sm:p-6">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold text-ocean-dark uppercase tracking-wider" id="ie-key-label">Edit text</h3>
      <button id="ie-close" class="text-text-secondary hover:text-ocean-dark text-xl leading-none">&times;</button>
    </div>
    <p class="text-xs text-text-secondary mb-3 font-mono break-all" id="ie-path"></p>
    <textarea
      id="ie-textarea"
      class="w-full min-h-[120px] p-3 border border-gray-200 rounded-lg text-sm font-mono leading-relaxed focus:outline-none focus:ring-2 focus:ring-ocean/40 resize-y"
    ></textarea>
    <p class="text-xs text-text-secondary mt-2">Use <code class="bg-gray-100 px-1 rounded">&lt;strong&gt;</code>, <code class="bg-gray-100 px-1 rounded">&lt;em&gt;</code>, <code class="bg-gray-100 px-1 rounded">&lt;br&gt;</code> for formatting.</p>
    <div class="flex justify-end gap-2 mt-4">
      <button id="ie-cancel" class="px-4 py-2 text-sm text-text-secondary hover:text-ocean-dark border border-gray-200 rounded-md">Cancel</button>
      <button id="ie-save" class="px-4 py-2 text-sm bg-ocean-dark text-white rounded-md hover:bg-ocean font-medium">Save</button>
    </div>
  </div>
</dialog>

<script>
  (function() {
    var lang = document.documentElement.lang || 'en';
    var editMode = false;
    var currentEl = null;

    var toggleBtn = document.getElementById('inline-editor-toggle');
    var editLabel = document.getElementById('edit-label');
    var pencilIcon = document.getElementById('edit-icon-pencil');
    var checkIcon = document.getElementById('edit-icon-check');
    var saveIndicator = document.getElementById('edit-save-indicator');
    var modal = document.getElementById('ie-modal');
    var textarea = document.getElementById('ie-textarea');
    var keyLabel = document.getElementById('ie-key-label');
    var pathLabel = document.getElementById('ie-path');
    var saveBtn = document.getElementById('ie-save');
    var cancelBtn = document.getElementById('ie-cancel');
    var closeBtn = document.getElementById('ie-close');

    function isIn(el, selector) {
      while (el) {
        if (el.matches && el.matches(selector)) return true;
        el = el.parentElement;
      }
      return false;
    }

    function shouldSkip(el) {
      var tag = el.tagName.toLowerCase();
      if (['script', 'style', 'svg', 'input', 'textarea', 'select', 'img', 'video', 'canvas', 'br', 'hr', 'iframe', 'noscript', 'template'].indexOf(tag) !== -1) return true;
      if (el.isContentEditable) return true;
      if (el.getAttribute && el.getAttribute('contenteditable') === 'true') return true;
      if (isIn(el, '#inline-editor-bar')) return true;
      if (isIn(el, '#ie-modal')) return true;
      return false;
    }

    function hasDirectText(el) {
      var children = el.childNodes;
      for (var i = 0; i < children.length; i++) {
        if (children[i].nodeType === 3) {
          var text = children[i].textContent.trim();
          if (text.length > 0) return true;
        }
      }
      return false;
    }

    function getCssPath(el) {
      var path = [];
      while (el && el.nodeType === 1) {
        if (el.tagName === 'BODY') { path.unshift('body'); break; }
        if (el.id) { path.unshift('#' + el.id); break; }
        var tag = el.tagName.toLowerCase();
        var parent = el.parentElement;
        if (parent) {
          var children = Array.from(parent.children);
          var sameTag = children.filter(function(c) { return c.tagName === el.tagName; });
          if (sameTag.length > 1) {
            var idx = children.indexOf(el) + 1;
            tag += ':nth-child(' + idx + ')';
          }
        }
        path.unshift(tag);
        el = parent;
      }
      return path.join(' > ');
    }

    function getPageKey() {
      var path = window.location.pathname.replace(/^\/(en|pl|ru)\/?/, '') || 'home';
      return path.replace(/\/$/, '') || 'home';
    }

    function makeStorageKey(el) {
      return 'p:' + getPageKey() + '::' + getCssPath(el);
    }

    function showSaved() {
      if (!saveIndicator) return;
      saveIndicator.classList.remove('hidden');
      setTimeout(function() { saveIndicator.classList.add('hidden'); }, 2000);
    }

    // ---- Apply overrides from embedded JSON (synchronous, no flash) ----
    function applyOverrides() {
      var script = document.getElementById('ie-data');
      if (!script) return;
      try {
        var overrides = JSON.parse(script.textContent);
        var all = document.querySelectorAll('body *');
        for (var i = 0; i < all.length; i++) {
          var el = all[i];
          if (shouldSkip(el)) continue;
          if (!hasDirectText(el)) continue;
          var key = '_any.' + makeStorageKey(el);
          if (overrides[key] !== undefined) {
            el.innerHTML = overrides[key];
          }
        }
      } catch {}
    }

    // ---- Edit mode ----
    function enterEditMode() {
      editMode = true;
      if (toggleBtn) toggleBtn.classList.add('bg-green-600');
      if (pencilIcon) pencilIcon.classList.add('hidden');
      if (checkIcon) checkIcon.classList.remove('hidden');
      if (editLabel) editLabel.textContent = 'Done';

      var all = document.querySelectorAll('body *');
      for (var i = 0; i < all.length; i++) {
        var el = all[i];
        if (shouldSkip(el)) continue;
        if (!hasDirectText(el)) continue;
        el.classList.add('ie-editing');
        el.addEventListener('click', handleClick);
      }
    }

    function exitEditMode() {
      editMode = false;
      if (toggleBtn) toggleBtn.classList.remove('bg-green-600');
      if (pencilIcon) pencilIcon.classList.remove('hidden');
      if (checkIcon) checkIcon.classList.add('hidden');
      if (editLabel) editLabel.textContent = 'Edit';

      var all = document.querySelectorAll('body *');
      for (var i = 0; i < all.length; i++) {
        var el = all[i];
        el.classList.remove('ie-editing', 'ie-editing-focus');
        el.removeEventListener('click', handleClick);
      }
      if (modal && modal.hasAttribute('open')) closeModal();
    }

    function handleClick(e) {
      if (!editMode) return;
      e.preventDefault();
      e.stopPropagation();

      var el = e.currentTarget;
      currentEl = el;

      var key = makeStorageKey(el);
      if (keyLabel) keyLabel.textContent = 'Editing';
      if (pathLabel) pathLabel.textContent = key;

      var html = el.innerHTML;
      var tmp = document.createElement('div');
      tmp.innerHTML = html;
      if (textarea) textarea.value = tmp.textContent || html;
      if (modal) modal.showModal();
    }

    async function saveEdit() {
      if (!currentEl || !textarea) return;
      var newValue = textarea.value;
      var key = makeStorageKey(currentEl);

      try {
        var res = await fetch('/api/admin/content', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            page: getPageKey(),
            section: '_any',
            key: key,
            lang: lang,
            value: newValue
          })
        });
        if (res.ok) {
          currentEl.innerHTML = newValue;
          showSaved();
          closeModal();
        }
      } catch {}
    }

    function closeModal() {
      if (modal) modal.close();
      currentEl = null;
    }

    if (toggleBtn) {
      toggleBtn.addEventListener('click', function() {
        if (editMode) exitEditMode();
        else enterEditMode();
      });
    }

    if (saveBtn) saveBtn.addEventListener('click', saveEdit);
    if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);

    if (modal) {
      modal.addEventListener('click', function(e) {
        if (e.target === modal) closeModal();
      });
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        if (modal && modal.hasAttribute('open')) { closeModal(); return; }
        if (editMode) exitEditMode();
      }
    });

    if (textarea) {
      textarea.addEventListener('keydown', function(e) {
        if (e.ctrlKey && e.key === 'Enter') {
          e.preventDefault();
          saveEdit();
        }
      });
    }

    // Run immediately — data is already in the HTML
    applyOverrides();
  })();
</script>
