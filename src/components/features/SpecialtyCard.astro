---
import Card from '../ui/Card.astro';
import PayPalButton from '../../components/PayPalButton.astro';
import type { Specialty } from '../../types';

interface Props {
  specialty: Specialty;
  lang: string;
}

const { specialty, lang } = Astro.props;
---

<Card>
  <img src={specialty.image} alt={specialty.title} class="w-full h-48 object-cover rounded-t-lg" loading="lazy" />
  <div class="p-6">
    <h3 class="text-xl font-semibold text-primary mb-2">{specialty.title}</h3>
    <p class="text-text-secondary text-sm mb-4 line-clamp-2">{specialty.shortDescription}</p>
    <div class="flex items-center justify-between pt-4 border-t border-ocean-muted/10">
      <span class="text-lg font-semibold text-primary">€{specialty.price}</span>
      <PayPalButton 
        price={specialty.price.toString()}
        currency="EUR"
        productName={specialty.title}
        itemId={specialty.id}
        itemType="specialty"
        priceLabel="Book Now"
      />
    </div>
  </div>
</Card>