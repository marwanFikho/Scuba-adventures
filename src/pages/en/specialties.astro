---
import MainLayout from '../../layouts/MainLayout.astro';
import SpecialtyCard from '../../components/features/SpecialtyCard.astro';
import { getSpecialtiesByLang } from '../../lib/course-translations';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);
const specialties = getSpecialtiesByLang(lang);
---

<MainLayout title={t.specialties.title} description={t.specialties.description}>
  <section class="pt-28 pb-16 bg-background" data-animate="fade-up">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold" data-i18n-key="specialties.heading">{t.specialties.heading}</h1>
        <p class="text-lg text-text-secondary mt-3" data-i18n-key="specialties.subtitle">{t.specialties.subtitle}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {specialties.map(specialty => (
          <SpecialtyCard specialty={specialty} lang={lang} />
        ))}
      </div>
    </div>
  </section>
</MainLayout>
