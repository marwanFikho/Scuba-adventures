---
import MainLayout from '../../layouts/MainLayout.astro';
import { lucia } from '../../lib/auth';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';
import { dashboardService } from '../../services/dashboard.service';
import AdminCatalogPanel from '../../components/admin/AdminCatalogPanel.astro';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);

const { user, session } = await lucia.validateSession(Astro.cookies.get(lucia.sessionCookieName)?.value ?? "");
if (!session) return Astro.redirect(`/${lang}/signin`);

const data = await dashboardService.getAdminDashboard();
---

<MainLayout title="Admin Dashboard" description="Admin management panel.">
  <section class="pt-28 pb-16 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-10">
        <div>
          <h1 class="text-4xl font-bold" data-i18n-key="admin.title">Admin Dashboard</h1>
          <p class="text-text-secondary mt-2" data-i18n-key="admin.description">Manage courses, specialties, and more.</p>
        </div>
        <form method="POST" action="/api/logout">
          <button type="submit" class="text-red-500 hover:underline" data-i18n-key="dashboard.logout">{t.dashboard.logout}</button>
        </form>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <div class="bg-surface rounded-xl shadow-premium p-6">
          <p class="text-text-secondary" data-i18n-key="admin.stats.activeCourses">Active Courses</p>
          <p class="text-3xl font-bold mt-2">{data.stats.activeCourses}</p>
        </div>
        <div class="bg-surface rounded-xl shadow-premium p-6">
          <p class="text-text-secondary" data-i18n-key="admin.stats.specialties">Specialties</p>
          <p class="text-3xl font-bold mt-2">{data.stats.specialties}</p>
        </div>
        <div class="bg-surface rounded-xl shadow-premium p-6">
          <p class="text-text-secondary" data-i18n-key="admin.stats.totalBookings">Total Bookings</p>
          <p class="text-3xl font-bold mt-2">{data.stats.totalBookings}</p>
        </div>
      </div>

      <AdminCatalogPanel t={t} data={data} />
    </div>
  </section>
</MainLayout>
