---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Checkout | Scuba Adventures">
  <main class="max-w-2xl mx-auto my-12 p-6 bg-green-900 rounded-xl shadow-2xl text-white">
    <h1 class="text-3xl md:text-4xl font-bold mb-8 text-center">Checkout</h1>
    
    <div class="mb-6 p-4 bg-black rounded-lg">
      <h2 class="text-xl font-semibold mb-2">Order Summary</h2>
      <p id="trip-name" class="text-slate-300">Loading trip details...</p>
      <p class="text-2xl font-bold mt-2 text-yellow-500">$<span id="trip-price">0.00</span></p>
    </div>

    <form id="checkout-form" class="space-y-4 mb-8">
      <h2 class="text-xl font-semibold mb-2 text-slate-200">Customer Information</h2>
      
      <div>
        <label for="full-name" class="block text-sm font-medium text-slate-400 mb-1">Full Name</label>
        <input type="text" id="full-name" required class="w-full p-3 rounded-lg bg-black border border-slate-700 text-white focus:outline-none focus:border-teal-500 transition" placeholder="John Doe" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="email" class="block text-sm font-medium text-slate-400 mb-1">Email Address</label>
          <input type="email" id="email" required class="w-full p-3 rounded-lg bg-black border border-slate-700 text-white focus:outline-none focus:border-teal-500 transition" placeholder="john@example.com" />
        </div>
        <div>
          <label for="phone" class="block text-sm font-medium text-slate-400 mb-1">Phone Number</label>
          <input type="tel" id="phone" required class="w-full p-3 rounded-lg bg-black border border-slate-700 text-white focus:outline-none focus:border-teal-500 transition" placeholder="+20 123 456 7890" />
        </div>
      </div>

      <div>
        <label for="trip-date" class="block text-sm font-medium text-slate-400 mb-1">Trip Date</label>
        <input type="date" id="trip-date" required class="w-full p-3 rounded-lg bg-black border border-slate-700 text-white focus:outline-none focus:border-teal-500 transition" />
      </div>
    </form>
    
    <div id="paypal-container-wrapper" class="hidden opacity-0 transition-opacity duration-300">
      <div id="paypal-button-container" class="w-full min-w-[250px]"></div>
    </div>

    <button id="confirm-btn" type="button" class="w-full bg-yellow-500 hover:bg-teal-600 text-slate-950 font-bold p-3 rounded-lg transition shadow-lg">
      Proceed to Payment
    </button>
  </main>
</Layout>

<script is:inline src="https://www.paypal.com/sdk/js?client-id==EUR"></script>

<script is:inline>
  // 1. قراءة البيانات الديناميكية من الرابط
  const urlParams = new URLSearchParams(window.location.search);
  const price = urlParams.get('price') || '0.00'; 
  const tripName = urlParams.get('trip') || 'Scuba Diving Trip';

  document.getElementById('trip-price').innerText = price;
  document.getElementById('trip-name').innerText = decodeURIComponent(tripName);

  const form = document.getElementById('checkout-form');
  const confirmBtn = document.getElementById('confirm-btn');
  const paypalWrapper = document.getElementById('paypal-container-wrapper');

  // 2. التحقق من صحة الـ Inputs قبل إظهار زرار باي بال
  confirmBtn.addEventListener('click', () => {
    if (form.checkValidity()) {
      // إخفاء زرار التأكيد وإظهار أزرار باي بال بحركة ناعمة
      confirmBtn.classList.add('hidden');
      paypalWrapper.classList.remove('hidden');
      setTimeout(() => {
        paypalWrapper.classList.add('opacity-100');
      }, 10);
    } else {
      form.reportValidity(); // هيظهر للعميل الحقول الناقصة تلقائياً
    }
  });

  // 3. تشغيل باي بال
  if (typeof paypal !== 'undefined' && price !== '0.00') {
    paypal.Buttons({
      createOrder: function(data, actions) {
        // تجميع بيانات الـ Inputs لإرسالها أو استخدامها
        const customerData = {
          name: document.getElementById('full-name').value,
          email: document.getElementById('email').value,
          phone: document.getElementById('phone').value,
          date: document.getElementById('trip-date').value
        };
        console.log('Customer Booking Data:', customerData);

        return actions.order.create({
          purchase_units: [{
            amount: {
              value: price
            },
            description: `${tripName} - Date: ${customerData.date}`
          }]
        });
      },
      onApprove: function(data, actions) {
        return actions.order.capture().then(function(details) {
          alert('Transaction completed by ' + details.payer.name.given_name);
          window.location.href = '/success';
        });
      },
      onError: function(err) {
        console.error('PayPal Error: ', err);
      }
    }).render('#paypal-button-container');
  } else if (price === '0.00') {
    document.getElementById('paypal-button-container').innerHTML = '<p class="text-red-500">Error: Invalid price amount.</p>';
  }
</script>