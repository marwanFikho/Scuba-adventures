---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCourseById } from '../../../lib/course-translations';
import { getLangFromPathname, getTranslations } from '../../../lib/i18n';
import { formatDescription } from '../../../lib/format-description';
// تم إضافة استيراد زر الباي بال هنا بشكل صحيح لتجنب خطأ ReferenceError
import PayPalButton from '../../../components/PayPalButton.astro';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);

const courseId = Astro.params.courseId;
const course = getCourseById(courseId!, lang);

if (!course) {
  return Astro.redirect(`/${lang}/courses`);
}

const dayLabel = course.durationDays === 1 ? t.courses.day : t.courses.days;
const formattedDescription = formatDescription(course.longDescription);
---

<MainLayout title={course.title} description={course.shortDescription}>
  <section class="pt-28 pb-16 bg-background" data-animate="fade-up">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={`/${lang}/courses`} class="text-ocean-dark hover:underline mb-8 inline-block font-medium" data-i18n-key="courses.backToCourses">← {t.courses.backToCourses}</a>
      
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="relative h-96 overflow-hidden rounded-xl shadow-premium">
          <img src={course.image} alt={course.title} class="w-full h-full object-cover" loading="lazy" />
        </div>
        
        <div>
          <h1 class="text-4xl font-bold text-primary mb-4">{course.title}</h1>
          
          <div class="bg-surface border border-gray-200/50 rounded-lg p-6 space-y-4 mb-8">
            {course.price && (
              <div class="flex items-center justify-between pb-4 border-b border-gray-200">
                <span class="text-text-secondary" data-i18n-key="courses.price">{t.courses.price}</span>
                <span class="text-3xl font-bold text-primary">€{course.price}</span>
              </div>
            )}
            
            {course.durationDays && (
              <div class="flex items-center justify-between pb-4 border-b border-gray-200">
                <span class="text-text-secondary" data-i18n-key="courses.duration">{t.courses.duration}</span>
                <span class="font-semibold">{course.durationDays} {dayLabel}</span>
              </div>
            )}
            
            {course.equipment && (
              <div class="flex items-center justify-between pb-4 border-b border-gray-200">
                <span class="text-text-secondary" data-i18n-key="courses.equipment">{t.courses.equipment}</span>
                <span class="font-semibold">{course.equipment}</span>
              </div>
            )}
            
            {course.requirements && (
              <div class="requirements-row">
                <span class="text-text-secondary requirements-label" data-i18n-key="courses.requirements">{t.courses.requirements}</span>
                <span class="requirements-value">{course.requirements}</span>
              </div>
            )}
          </div>
          
          <!-- Price & PayPal Button (تم تعديل التنسيق ليتطابق تماماً مع image_6.png) -->
          <div class="bg-[#fcfbf9] border border-gray-200 rounded-xl p-6 mb-8 shadow-sm">
            <h3 class="text-lg font-bold text-[#1e3a5f] mb-1">Price</h3>
            <p class="text-3xl font-bold text-[#b48454] mb-2">
              {course.currency || 'EUR'} {course.price ? course.price.toFixed(2) : '0.00'}
            </p>
            <p class="text-sm text-gray-500 mb-6">Free transfer from Hurghada hotels included</p>
            
            <PayPalButton 
                price={course.price}
                currency={course.currency || 'EUR'}
                productName={course.title}
                itemId={course.id}
                itemType="course"
                priceLabel="Book Now"
            />
          </div>
        </div>
      </div>
      
      <div class="mb-12 formatted-description" set:html={formattedDescription} />
      
      <div class="grid md:grid-cols-2 gap-12 mb-12">
        {course.includes && course.includes.length > 0 && (
          <div>
            <h3 class="text-xl font-bold text-primary mb-4" data-i18n-key="courses.includes">{t.courses.includes}</h3>
            <ul class="space-y-3">
              {course.includes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="text-accent mt-1 font-bold">✓</span>
                  <span class="text-text-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        
        {course.excludes && course.excludes.length > 0 && (
          <div>
            <h3 class="text-xl font-bold text-primary mb-4" data-i18n-key="courses.excludes">{t.courses.excludes}</h3>
            <ul class="space-y-3">
              {course.excludes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="text-accent mt-1 font-bold">−</span>
                  <span class="text-text-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .formatted-description {
    max-width: 100%;
  }
  
  .formatted-description h3.description-heading {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0c4a6e;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #0ea5e9;
  }
  
  .formatted-description h3.description-heading:first-child {
    margin-top: 0;
  }
  
  .formatted-description p {
    color: #4b5563;
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }
  
  .formatted-description em.italic-term {
    font-style: italic;
    color: #0369a1;
    font-weight: 500;
  }
  
  .formatted-description strong.highlight-text {
    color: #0c4a6e;
    font-weight: 700;
    background: linear-gradient(180deg, transparent 60%, #dbeafe 60%);
    padding: 0 2px;
  }
  
  .formatted-description ul.description-list {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1rem;
  }
  
  .formatted-description ul.description-list li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
    color: #4b5563;
    line-height: 1.6;
  }
  
  .formatted-description ul.description-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 6px;
    height: 6px;
    background: #0ea5e9;
    border-radius: 50%;
  }
  
  .requirements-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid #e5e7eb;
  }
  
  .requirements-label {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
  }
  
  .requirements-value {
    font-size: 0.95rem;
    color: #374151;
    line-height: 1.6;
  }
</style>