---
import MainLayout from '../../layouts/MainLayout.astro';
import Button from '../../components/ui/Button.astro';
import CourseCard from '../../components/features/CourseCard.astro';
import TestimonialCard from '../../components/features/TestimonialCard.astro';
import { getCoursesByLang } from '../../lib/course-translations';
import { getHeroImage } from '../../lib/catalog';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);
const basePath = `/${lang}`;
const courses = getCoursesByLang(lang).slice(0, 3);

const testimonialsEN = [
  { name: "Ava Holm", role: "Advanced Diver", quote: "The training felt calm, intentional, and incredibly premium. I left with full confidence in my skills." },
  { name: "Luca Marin", role: "Underwater Photographer", quote: "Every detail was thoughtfully curated. The courses are structured for serious growth." },
  { name: "Nina Volkova", role: "Traveler", quote: "A beautiful balance of safety, elegance, and adventure. The trips are unforgettable." }
];

const testimonialsPL = [
  { name: "Ava Holm", role: "Zaawansowany nurek", quote: "Szkolenie było spokojne, przemyślane i niezwykle profesjonalne. Wyszedłem z pełną pewnością swoich umiejętności." },
  { name: "Luca Marin", role: "Fotograf podwodny", quote: "Każdy detal był przemyślany. Kursy są ułożone dla poważnego rozwoju." },
  { name: "Nina Volkova", role: "Podróżniczka", quote: "Piękne połączenie bezpieczeństwa, elegancji i przygody. Wyjazdy są niezapomniane." }
];

const testimonialsRU = [
  { name: "Ava Holm", role: "Продвинутый дайвер", quote: "Обучение было спокойным, продуманным и невероятно профессиональным. Я ушёл с полной уверенностью в своих навыках." },
  { name: "Luca Marin", role: "Подводный фотограф", quote: "Каждая деталь была продумана. Курсы структурированы для серьёзного роста." },
  { name: "Nina Volkova", role: "Путешественница", quote: "Прекрасный баланс безопасности, элегантности и приключений. Поездки незабываемы." }
];

const testimonials = lang === 'pl' ? testimonialsPL : lang === 'ru' ? testimonialsRU : testimonialsEN;
---

<MainLayout title={t.home.title} description={t.home.description}>
	<section class="relative h-screen" data-animate="hero">
		<img src={getHeroImage()} alt="Scuba diver underwater" class="absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" />
		<div class="absolute inset-0 bg-primary/50"></div>
		<div class="relative z-10 flex flex-col items-center justify-center h-full text-center text-white px-4">
			<h1 class="text-5xl md:text-7xl font-bold mb-4 text-white">{t.home.heroTitle}</h1>
			<p class="text-lg md:text-xl max-w-2xl mb-8 text-white/90">{t.home.heroSubtitle}</p>
			<div class="flex space-x-4">
				<Button href={`${basePath}/courses`} variant="primary" size="lg">{t.home.exploreCourses}</Button>
			</div>
		</div>
	</section>

	<section id="about" class="py-20 bg-background" data-animate="fade-up">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-4xl font-bold mb-4">{t.home.aboutTitle}</h2>
			<p class="text-lg text-text-secondary max-w-3xl mx-auto">{t.home.aboutText}</p>
		</div>
	</section>

	<section class="py-20 bg-background" data-animate="fade-up">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-4xl font-bold">{t.home.coursesTitle}</h2>
				<p class="text-text-secondary mt-3">{t.home.coursesSubtitle}</p>
			</div>
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
				{courses.map((course) => (
					<CourseCard course={course} lang={lang} />
				))}
			</div>
		</div>
	</section>

	<section class="py-20 bg-surface" data-animate="fade-up">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-4xl font-bold">{t.home.testimonialsTitle}</h2>
				<p class="text-text-secondary mt-3">{t.home.testimonialsSubtitle}</p>
			</div>
			<div class="grid md:grid-cols-3 gap-8">
				{testimonials.map((testimonial) => (
					<TestimonialCard testimonial={testimonial} />
				))}
			</div>
		</div>
	</section>

	<section class="py-20 bg-background" data-animate="fade-up">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="bg-primary text-white rounded-2xl px-8 py-12 md:px-16 md:py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-8 shadow-premium">
				<div>
					<h2 class="text-4xl font-bold">{t.home.ctaTitle}</h2>
					<p class="text-lg text-white/80 mt-3">{t.home.ctaSubtitle}</p>
				</div>
				<div class="flex gap-4">
					<Button href={`${basePath}/courses`} variant="secondary" size="lg">{t.home.ctaCourses}</Button>
					<Button href={`${basePath}/contact`} variant="outline" size="lg">{t.home.ctaContact}</Button>
				</div>
			</div>
		</div>
	</section>
</MainLayout>
