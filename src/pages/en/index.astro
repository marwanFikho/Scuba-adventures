---
import MainLayout from '../../layouts/MainLayout.astro';
import Button from '../../components/ui/Button.astro';
import CourseCard from '../../components/features/CourseCard.astro';
import TestimonialCard from '../../components/features/TestimonialCard.astro';
import { getCoursesByLang } from '../../lib/course-translations';
import { getHeroImage } from '../../lib/catalog';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);
const basePath = `/${lang}`;
const courses = getCoursesByLang(lang).slice(0, 3);

const testimonialsEN = [
  { name: "Ava Holm", role: "Advanced Diver", quote: "The training felt calm, intentional, and incredibly premium. I left with full confidence in my skills." },
  { name: "Luca Marin", role: "Underwater Photographer", quote: "Every detail was thoughtfully curated. The courses are structured for serious growth." },
  { name: "Nina Volkova", role: "Traveler", quote: "A beautiful balance of safety, elegance, and adventure. The trips are unforgettable." }
];

const testimonialsPL = [
  { name: "Ava Holm", role: "Zaawansowany nurek", quote: "Szkolenie było spokojne, przemyślane i niezwykle profesjonalne. Wyszedłem z pełną pewnością swoich umiejętności." },
  { name: "Luca Marin", role: "Fotograf podwodny", quote: "Każdy detal był przemyślany. Kursy są ułożone dla poważnego rozwoju." },
  { name: "Nina Volkova", role: "Podróżniczka", quote: "Piękne połączenie bezpieczeństwa, elegancji i przygody. Wyjazdy są niezapomniane." }
];

const testimonialsRU = [
  { name: "Ava Holm", role: "Продвинутый дайвер", quote: "Обучение было спокойным, продуманным и невероятно профессиональным. Я ушёл с полной уверенностью в своих навыках." },
  { name: "Luca Marin", role: "Подводный фотограф", quote: "Каждая деталь была продумана. Курсы структурированы для серьёзного роста." },
  { name: "Nina Volkova", role: "Путешественница", quote: "Прекрасный баланс безопасности, элегантности и приключений. Поездки незабываемы." }
];

const testimonials = lang === 'pl' ? testimonialsPL : lang === 'ru' ? testimonialsRU : testimonialsEN;
---

<MainLayout title={t.home.title} description={t.home.description}>
	<section class="relative h-screen min-h-[600px]" data-animate="hero">
		<img src={getHeroImage()} alt="Scuba diver underwater" class="absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" />
		<div class="absolute inset-0 bg-gradient-to-b from-ocean-dark/75 via-ocean-dark/60 to-ocean-dark/85"></div>
		<div class="relative z-10 flex flex-col items-center justify-center h-full text-center text-white px-4 sm:px-6">
			<h1 class="text-3xl sm:text-5xl md:text-7xl font-bold mb-4 text-white drop-shadow-lg leading-tight" data-i18n-key="home.heroTitle">{t.home.heroTitle}</h1>
			<p class="text-base sm:text-lg md:text-xl max-w-2xl mb-8 text-white/95 drop-shadow" data-i18n-key="home.heroSubtitle">{t.home.heroSubtitle}</p>
			<div class="flex flex-col sm:flex-row gap-3 sm:space-x-4 w-full sm:w-auto">
				<Button href={`${basePath}/courses`} variant="primary" size="lg" class="w-full sm:w-auto" data-i18n-key="home.exploreCourses">{t.home.exploreCourses}</Button>
			</div>
		</div>
	</section>

	<section id="about" class="py-12 sm:py-20 bg-gradient-to-b from-background to-surface" data-animate="fade-up">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-2xl sm:text-4xl font-bold mb-4 text-gradient" data-i18n-key="home.aboutTitle">{t.home.aboutTitle}</h2>
			<p class="text-base sm:text-lg text-text-secondary max-w-3xl mx-auto" data-i18n-key="home.aboutText">{t.home.aboutText}</p>
		</div>
	</section>

	<section class="py-12 sm:py-20 bg-surface" data-animate="fade-up">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8 sm:mb-12">
				<h2 class="text-2xl sm:text-4xl font-bold text-gradient" data-i18n-key="home.coursesTitle">{t.home.coursesTitle}</h2>
				<p class="text-text-secondary mt-3" data-i18n-key="home.coursesSubtitle">{t.home.coursesSubtitle}</p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
				{courses.map((course) => (
					<CourseCard course={course} lang={lang} />
				))}
			</div>
		</div>
	</section>

	<section class="py-12 sm:py-20 bg-gradient-to-br from-ocean-dark via-ocean to-ocean-muted" data-animate="fade-up">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8 sm:mb-12">
				<h2 class="text-2xl sm:text-4xl font-bold text-white" data-i18n-key="home.testimonialsTitle">{t.home.testimonialsTitle}</h2>
				<p class="text-white/90 mt-3" data-i18n-key="home.testimonialsSubtitle">{t.home.testimonialsSubtitle}</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
				{testimonials.map((testimonial) => (
					<TestimonialCard testimonial={testimonial} />
				))}
			</div>
		</div>
	</section>

	<section class="py-12 sm:py-20 bg-background" data-animate="fade-up">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="bg-gradient-to-r from-ocean-dark to-ocean-muted text-white rounded-2xl px-6 sm:px-8 md:px-16 py-10 sm:py-12 md:py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-6 sm:gap-8 shadow-premium border border-ocean-muted/30">
				<div class="text-center md:text-left">
					<h2 class="text-2xl sm:text-4xl font-bold text-white" data-i18n-key="home.ctaTitle">{t.home.ctaTitle}</h2>
					<p class="text-base sm:text-lg text-white/95 mt-3" data-i18n-key="home.ctaSubtitle">{t.home.ctaSubtitle}</p>
				</div>
				<div class="flex flex-col sm:flex-row gap-3 sm:gap-4 w-full md:w-auto">
					<Button href={`${basePath}/courses`} variant="accent" size="lg" class="w-full sm:w-auto" data-i18n-key="home.ctaCourses">{t.home.ctaCourses}</Button>
					<Button href={`${basePath}/contact`} variant="outline-white" size="lg" class="w-full sm:w-auto" data-i18n-key="home.ctaContact">{t.home.ctaContact}</Button>
				</div>
			</div>
		</div>
	</section>
</MainLayout>
