---
import MainLayout from '../../layouts/MainLayout.astro';
import Button from '../../components/ui/Button.astro';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);
const basePath = `/${lang}`;
---

<MainLayout title={t.booking.cancelTitle} description={t.booking.cancelDesc}>
  <section class="pt-28 pb-24 bg-background">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-bold" data-i18n-key="booking.cancelHeading">{t.booking.cancelHeading}</h1>
      <p class="text-lg text-text-secondary mt-4" data-i18n-key="booking.cancelText">{t.booking.cancelText}</p>
      <div class="mt-8">
        <Button href={`${basePath}/courses`} data-i18n-key="booking.backCourses">{t.booking.backCourses}</Button>
      </div>
    </div>
  </section>
</MainLayout>
