---
import MainLayout from '../../layouts/MainLayout.astro';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);
---

<MainLayout title={t.privacy.title} description={t.privacy.description}>
  <section class="pt-28 pb-16 bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
      <h1 class="text-4xl font-bold">{t.privacy.heading}</h1>
      <p class="text-text-secondary">{t.privacy.p1}</p>
      <p class="text-text-secondary">{t.privacy.p2}</p>
    </div>
  </section>
</MainLayout>
