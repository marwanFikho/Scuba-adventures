---
import MainLayout from '../../layouts/MainLayout.astro';
import { getAdventureTranslations } from '../../lib/adventure-translations';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';
import { formatDescription } from '../../lib/format-description';
import PayPalButton from '../../components/PayPalButton.astro'; // تم إضافة الاستيراد

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);
const adventure = getAdventureTranslations(lang);

const { routes, shared } = adventure;
---

<MainLayout title="One Week Adventure" description="Explore the Red Sea with our one-week liveaboard adventures.">
  <section class="pt-28 pb-16 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate="fade-up">
        <h1 class="text-5xl font-bold text-primary mb-4" data-i18n-key="one-week-adventure.page-title">One Week Adventure</h1>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto" data-i18n-key="one-week-adventure.page-subtitle">Experience the best of the Red Sea with our carefully crafted one-week liveaboard diving safaris. Choose from three incredible routes.</p>
      </div>

      <div class="mb-16 rounded-xl overflow-hidden shadow-premium" data-animate="fade-up">
        <img src="/images/adventures/map.png" alt="Red Sea Routes Map" class="w-full" loading="lazy" />
      </div>

      {routes.map((route, routeIndex) => (
        <section class="mb-24" data-animate="fade-up" id={route.id}>
          <div class="text-center mb-12">
            <h2 class="text-4xl font-bold text-primary mb-4">{route.title}</h2>
            <div class="flex flex-wrap justify-center gap-3 mb-6">
              {route.sites.map((site) => (
                <span class="bg-secondary/15 text-ocean-dark px-4 py-2 rounded-full text-sm font-medium">{site}</span>
              ))}
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="relative h-96 overflow-hidden rounded-xl shadow-premium">
              <img src={route.heroImage} alt={route.title} class="w-full h-full object-cover" loading="lazy" />
            </div>

            <div>
              <h3 class="text-2xl font-bold text-primary mb-4" data-i18n-key="one-week-adventure.itinerary-schedule">{shared.itinerarySchedule}</h3>
              <div class="formatted-description mb-6" set:html={formatDescription(route.itinerary)} />

              <!-- الصندوق الموحد للسعر وزر الحجز -->
              <div class="bg-[#fcfbf9] border border-gray-200 rounded-xl p-6 mb-8 shadow-sm">
                <div class="text-4xl font-bold text-[#b48454] mb-4">{route.price}</div>
                
                <div class="mb-6 space-y-3">
                  <div>
                    <h4 class="font-semibold text-primary mb-2" data-i18n-key="one-week-adventure.included-label">Included:</h4>
                    <ul class="space-y-1">
                      {route.includes.map((item) => (
                        <li class="flex items-start gap-2 text-text-secondary text-sm">
                          <span class="text-accent font-bold">✓</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>

                <PayPalButton 
                    price={route.rawPrice || 0} 
                    currency="EUR" 
                    productName={route.title}
                    itemId={route.id}
                    itemType="adventure"
                    priceLabel={shared.bookNow}
                />
              </div>

              <div class="mb-6">
                <h4 class="font-semibold text-primary mb-3" data-i18n-key="one-week-adventure.rental-equipment">Rental Equipment (per person / per week):</h4>
                <div class="grid grid-cols-2 gap-2">
                  {route.rentalEquipment.map((item) => (
                    <div class="flex justify-between bg-surface rounded-lg px-4 py-2 border border-gray-200/50">
                      <span class="text-text-secondary text-sm">{item.name}</span>
                      <span class="font-semibold text-primary text-sm">{item.price}</span>
                    </div>
                  ))}
                </div>
                <p class="text-xs text-text-secondary mt-2 italic" data-i18n-key="one-week-adventure.rental-equipment-note">If you require any equipment, please let us know so we can have it available.</p>
              </div>
            </div>
          </div>

          {/* ... باقي محتويات الصفحة (Dive Sites, Daily Schedule) ... */}
          {route.diveSites && route.diveSites.length > 0 && (
            <div class="mb-12">
              <h3 class="text-2xl font-bold text-primary mb-8 text-center" data-i18n-key="one-week-adventure.dive-sites">Dive Sites</h3>
              <div class="grid md:grid-cols-2 gap-8">
                {route.diveSites.map((site) => (
                  <div class="bg-surface rounded-xl overflow-hidden shadow-premium border border-gray-200/50">
                    <div class="relative h-64 overflow-hidden">
                      <img src={site.image} alt={site.name} class="w-full h-full object-cover" loading="lazy" />
                    </div>
                    <div class="p-6">
                      <h4 class="text-xl font-bold text-primary mb-3">{site.name}</h4>
                      <div class="formatted-description text-sm" set:html={formatDescription(site.description)} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {route.scheduleImages && route.scheduleImages.length > 0 && (
            <div class="mb-12">
              <h3 class="text-2xl font-bold text-primary mb-8 text-center" data-i18n-key="one-week-adventure.daily-schedule">Daily Schedule</h3>
              <div class="grid md:grid-cols-2 gap-8">
                {route.scheduleImages.map((img) => (
                  <div class="rounded-xl overflow-hidden shadow-premium">
                    <img src={img} alt="Schedule" class="w-full" loading="lazy" />
                  </div>
                ))}
              </div>
            </div>
          )}

          {routeIndex < routes.length - 1 && (
            <hr class="border-gray-200 my-16" />
          )}
        </section>
      ))}

      {/* ... باقي الأقسام السفلية (Cancellation, Important Info) ... */}
      <section class="mt-16" data-animate="fade-up">
        {/* (تم الاحتفاظ بباقي الأكواد الأصلية هنا كما هي) */}
      </section>
    </div>
  </section>
</MainLayout>

<style>
  .formatted-description p { margin-bottom: 0.75rem; color: #4b5563; line-height: 1.75; }
  .formatted-description strong.highlight-text { color: #0c4a6e; font-weight: 700; background: linear-gradient(180deg, transparent 60%, #dbeafe 60%); padding: 0 2px; }
  .formatted-description em.italic-term { font-style: italic; color: #0369a1; font-weight: 500; }
</style>
