---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCourseById } from '../../../lib/course-translations';
import { getLangFromPathname, getTranslations } from '../../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);

const courseId = Astro.params.courseId;
const course = getCourseById(courseId!, lang);

if (!course) {
  return Astro.redirect(`/${lang}/courses`);
}

const dayLabel = course.durationDays === 1 ? t.courses.day : t.courses.days;
---

<MainLayout title={course.title} description={course.shortDescription}>
  <section class="pt-28 pb-16 bg-background" data-animate="fade-up">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={`/${lang}/courses`} class="text-secondary hover:underline mb-8 inline-block">← {t.courses.backToCourses}</a>
      
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="relative h-96 overflow-hidden rounded-xl shadow-premium">
          <img id="heroImage" src={course.images[0]} alt={course.title} class="w-full h-full object-cover transition-opacity duration-500" loading="lazy" />
          <button id="prevImage" class="absolute left-4 top-1/2 -translate-y-1/2 bg-black/50 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-black/70 transition-colors">‹</button>
          <button id="nextImage" class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/50 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-black/70 transition-colors">›</button>
          <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2" id="imageDots">
            {course.images.map((_, i) => (
              <button class="w-3 h-3 rounded-full bg-white/50 hover:bg-white transition-colors {i === 0 ? 'bg-white' : ''}" data-index={i}></button>
            ))}
          </div>
        </div>
        
        <div>
          <h1 class="text-4xl font-bold text-primary mb-4">{course.title}</h1>
          
          <div class="bg-surface border border-gray-200/50 rounded-lg p-6 space-y-4 mb-8">
            {course.price && (
              <div class="flex items-center justify-between pb-4 border-b border-gray-200">
                <span class="text-text-secondary">{t.courses.price}</span>
                <span class="text-3xl font-bold text-primary">€{course.price}</span>
              </div>
            )}
            
            {course.durationDays && (
              <div class="flex items-center justify-between pb-4 border-b border-gray-200">
                <span class="text-text-secondary">{t.courses.duration}</span>
                <span class="font-semibold">{course.durationDays} {dayLabel}</span>
              </div>
            )}
            
            {course.equipment && (
              <div class="flex items-center justify-between pb-4 border-b border-gray-200">
                <span class="text-text-secondary">{t.courses.equipment}</span>
                <span class="font-semibold">{course.equipment}</span>
              </div>
            )}
            
            {course.requirements && (
              <div class="flex items-center justify-between">
                <span class="text-text-secondary">{t.courses.requirements}</span>
                <span class="font-semibold">{course.requirements}</span>
              </div>
            )}
          </div>
          
          <button class="w-full bg-secondary text-white py-3 rounded-md font-semibold hover:bg-opacity-90 transition-colors">
            {t.common.bookNow}
          </button>
        </div>
      </div>
      
      <div class="mb-12">
        <div class="prose prose-sm max-w-none">
          {course.longDescription.split('\n\n').map((paragraph) => (
            <p class="text-text-secondary mb-4 leading-relaxed">{paragraph}</p>
          ))}
        </div>
      </div>
      
      <div class="grid md:grid-cols-2 gap-12 mb-12">
        {course.includes && course.includes.length > 0 && (
          <div>
            <h3 class="text-xl font-bold text-primary mb-4">{t.courses.includes}</h3>
            <ul class="space-y-3">
              {course.includes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="text-accent mt-1 font-bold">✓</span>
                  <span class="text-text-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        
        {course.excludes && course.excludes.length > 0 && (
          <div>
            <h3 class="text-xl font-bold text-primary mb-4">{t.courses.excludes}</h3>
            <ul class="space-y-3">
              {course.excludes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="text-accent mt-1 font-bold">−</span>
                  <span class="text-text-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .prose p {
    margin-bottom: 1rem;
  }
</style>

<script define:vars={{ images: course.images }}>
  let currentIndex = 0;
  
  const heroImage = document.getElementById('heroImage');
  const dots = document.querySelectorAll('#imageDots button');
  const prevBtn = document.getElementById('prevImage');
  const nextBtn = document.getElementById('nextImage');
  
  const updateImage = (index) => {
    currentIndex = index;
    heroImage.style.opacity = '0';
    setTimeout(() => {
      heroImage.src = images[currentIndex];
      heroImage.style.opacity = '1';
    }, 200);
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-white', i === currentIndex);
      dot.classList.toggle('bg-white/50', i !== currentIndex);
    });
  };
  
  prevBtn?.addEventListener('click', () => {
    updateImage((currentIndex - 1 + images.length) % images.length);
  });
  
  nextBtn?.addEventListener('click', () => {
    updateImage((currentIndex + 1) % images.length);
  });
  
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => updateImage(i));
  });
</script>
