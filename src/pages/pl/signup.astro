---
import MainLayout from '../../layouts/MainLayout.astro';
import Card from '../../components/ui/Card.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
import { authService } from '../../services/auth.service';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);
const basePath = `/${lang}`;

if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const email = formData.get('email');
        const password = formData.get('password');

        const sessionCookie = await authService.signup({ email, password });
        Astro.cookies.set(sessionCookie.name, sessionCookie.value, sessionCookie.attributes);
        return Astro.redirect(`${basePath}/dashboard`);

    } catch (error) {
        console.error(error);
    }
}
---

<MainLayout title={t.auth.signUpTitle} description={t.auth.signUpDesc}>
    <div class="max-w-md mx-auto py-20">
        <Card>
            <h1 class="text-3xl font-bold text-center mb-6" data-i18n-key="auth.createAccount">{t.auth.createAccount}</h1>
            <form method="POST" class="space-y-6">
                <div>
                    <label for="email" class="block text-sm font-medium text-text-secondary" data-i18n-key="auth.email">{t.auth.email}</label>
                    <Input type="email" name="email" id="email" placeholder={t.auth.emailPlaceholder} required data-i18n-key="auth.emailPlaceholder" />
                </div>
                <div>
                    <label for="password" class="block text-sm font-medium text-text-secondary" data-i18n-key="auth.password">{t.auth.password}</label>
                    <Input type="password" name="password" id="password" placeholder={t.auth.passwordPlaceholder} required data-i18n-key="auth.passwordPlaceholder" />
                </div>
                <Button type="submit" class="w-full" size="lg" data-i18n-key="auth.signUp">{t.auth.signUp}</Button>
            </form>
            <p class="mt-6 text-center text-sm text-text-secondary" data-i18n-key="auth.hasAccount">
                {t.auth.hasAccount} <a href={`${basePath}/signin`} class="font-medium text-ocean-dark hover:underline" data-i18n-key="auth.signIn">{t.auth.signIn}</a>
            </p>
        </Card>
    </div>
</MainLayout>
