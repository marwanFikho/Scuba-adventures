---
import MainLayout from '../../layouts/MainLayout.astro';
import { getAdventureTranslations } from '../../lib/adventure-translations';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';
import { formatDescription } from '../../lib/format-description';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);
const adventure = getAdventureTranslations(lang);

const { routes, shared } = adventure;
---

<MainLayout title="Jednotygodniowa Przygoda" description="Odkryj Morze Czerwone z naszymi jednonotygodniowymi rejsami nurkowymi.">
  <section class="pt-28 pb-16 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate="fade-up">
        <h1 class="text-5xl font-bold text-primary mb-4" data-i18n-key="one-week-adventure.page-title">Jednotygodniowa Przygoda</h1>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto" data-i18n-key="one-week-adventure.page-subtitle">Doświadcz najlepszego z Morza Czerwonego z naszymi starannie przygotowanymi jednonotygodniowymi rejsami nurkowymi. Wybierz jedną z trzech niesamowitych tras.</p>
      </div>

      <div class="mb-16 rounded-xl overflow-hidden shadow-premium" data-animate="fade-up">
        <img src="/images/adventures/map.png" alt="Mapa Tras Morza Czerwonego" class="w-full" loading="lazy" />
      </div>

      {routes.map((route, routeIndex) => (
        <section class="mb-24" data-animate="fade-up" id={route.id}>
          <div class="text-center mb-12">
            <h2 class="text-4xl font-bold text-primary mb-4">{route.title}</h2>
            <div class="flex flex-wrap justify-center gap-3 mb-6">
              {route.sites.map((site) => (
                <span class="bg-secondary/10 text-secondary px-4 py-2 rounded-full text-sm font-medium">{site}</span>
              ))}
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="relative h-96 overflow-hidden rounded-xl shadow-premium">
              <img src={route.heroImage} alt={route.title} class="w-full h-full object-cover" loading="lazy" />
            </div>

            <div>
              <h3 class="text-2xl font-bold text-primary mb-4" data-i18n-key="one-week-adventure.itinerary-schedule">{shared.itinerarySchedule}</h3>
              <div class="formatted-description mb-6" set:html={formatDescription(route.itinerary)} />

              <div class="bg-surface border border-gray-200/50 rounded-lg p-6 mb-6">
                <div class="text-4xl font-bold text-primary mb-4">{route.price}</div>
                <div class="space-y-3">
                  <div>
                    <h4 class="font-semibold text-primary mb-2" data-i18n-key="one-week-adventure.included-label">W cenie:</h4>
                    <ul class="space-y-1">
                      {route.includes.map((item) => (
                        <li class="flex items-start gap-2 text-text-secondary text-sm">
                          <span class="text-accent font-bold">✓</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-primary mb-2" data-i18n-key="one-week-adventure.not-included-label">Nie w cenie:</h4>
                    <ul class="space-y-1">
                      {route.excludes.map((item) => (
                        <li class="flex items-start gap-2 text-text-secondary text-sm">
                          <span class="text-red-500 font-bold">−</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>

              <div class="mb-6">
                <h4 class="font-semibold text-primary mb-3" data-i18n-key="one-week-adventure.rental-equipment">Sprzęt do wynajęcia (na osobę / na tydzień):</h4>
                <div class="grid grid-cols-2 gap-2">
                  {route.rentalEquipment.map((item) => (
                    <div class="flex justify-between bg-surface rounded-lg px-4 py-2 border border-gray-200/50">
                      <span class="text-text-secondary text-sm">{item.name}</span>
                      <span class="font-semibold text-primary text-sm">{item.price}</span>
                    </div>
                  ))}
                </div>
                <p class="text-xs text-text-secondary mt-2 italic" data-i18n-key="one-week-adventure.rental-equipment-note">Jeśli potrzebujesz sprzętu, daj nam znać, abyśmy mogli go przygotować.</p>
              </div>

              <a href={`/${lang}/contact`} class="block w-full bg-secondary text-white py-3 rounded-md font-semibold hover:bg-opacity-90 transition-colors text-center" data-i18n-key="one-week-adventure.book-now">
                {shared.bookNow}
              </a>
            </div>
          </div>

          {route.diveSites && route.diveSites.length > 0 && (
            <div class="mb-12">
              <h3 class="text-2xl font-bold text-primary mb-8 text-center" data-i18n-key="one-week-adventure.dive-sites">Miejsca Nurkowe</h3>
              <div class="grid md:grid-cols-2 gap-8">
                {route.diveSites.map((site) => (
                  <div class="bg-surface rounded-xl overflow-hidden shadow-premium border border-gray-200/50">
                    <div class="relative h-64 overflow-hidden">
                      <img src={site.image} alt={site.name} class="w-full h-full object-cover" loading="lazy" />
                    </div>
                    <div class="p-6">
                      <h4 class="text-xl font-bold text-primary mb-3">{site.name}</h4>
                      <div class="formatted-description text-sm" set:html={formatDescription(site.description)} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {route.scheduleImages && route.scheduleImages.length > 0 && (
            <div class="mb-12">
              <h3 class="text-2xl font-bold text-primary mb-8 text-center" data-i18n-key="one-week-adventure.daily-schedule">Harmonogram Dzienny</h3>
              <div class="grid md:grid-cols-2 gap-8">
                {route.scheduleImages.map((img) => (
                  <div class="rounded-xl overflow-hidden shadow-premium">
                    <img src={img} alt="Harmonogram" class="w-full" loading="lazy" />
                  </div>
                ))}
              </div>
            </div>
          )}

          {routeIndex < routes.length - 1 && (
            <hr class="border-gray-200 my-16" />
          )}
        </section>
      ))}

      <section class="mt-16" data-animate="fade-up">
        <div class="bg-surface rounded-xl p-8 border border-gray-200/50 shadow-premium">
          <h2 class="text-3xl font-bold text-primary mb-6" data-i18n-key="one-week-adventure.cancellation-policy">{shared.cancellationPolicy}</h2>
          <p class="text-text-secondary mb-6" data-i18n-key="one-week-adventure.cancellation-intro">{shared.cancellationIntro}</p>

          <h3 class="text-xl font-semibold text-primary mb-3" data-i18n-key="one-week-adventure.cancellation-conditions">{shared.cancellationConditions}</h3>
          <ul class="space-y-2 mb-6">
            {[shared.cancellation90, shared.cancellation21, shared.cancellation14, shared.cancellationNoRefund].map((item) => (
              <li class="flex items-start gap-2 text-text-secondary">
                <span class="text-accent mt-1">•</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <h3 class="text-xl font-semibold text-primary mb-3" data-i18n-key="one-week-adventure.cancellation-method">{shared.cancellationMethod}</h3>
          <p class="text-text-secondary mb-3" data-i18n-key="one-week-adventure.cancellation-method-desc">{shared.cancellationMethodDesc}</p>
          <ul class="space-y-1 mb-8 ml-4">
            {[shared.cancellationBookingNumber, shared.cancellationFullName, shared.cancellationTravelDate].map((item) => (
              <li class="flex items-start gap-2 text-text-secondary">
                <span class="text-accent">•</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="mt-12" data-animate="fade-up">
        <div class="bg-surface rounded-xl p-8 border border-gray-200/50 shadow-premium">
          <h2 class="text-3xl font-bold text-primary mb-6" data-i18n-key="one-week-adventure.important-info">{shared.importantInfo}</h2>

          <div class="space-y-8">
            <div>
              <h3 class="text-xl font-semibold text-primary mb-3" data-i18n-key="one-week-adventure.travel-times">{shared.travelTimes}</h3>
              <ul class="space-y-1 ml-4">
                <li class="text-text-secondary" data-i18n-key="one-week-adventure.program-begins">• {shared.programBegins}</li>
                <li class="text-text-secondary" data-i18n-key="one-week-adventure.program-ends">• {shared.programEnds}</li>
              </ul>
            </div>

            <div>
              <h3 class="text-xl font-semibold text-primary mb-3" data-i18n-key="one-week-adventure.payments">{shared.payments}</h3>
              <p class="text-text-secondary mb-2" data-i18n-key="one-week-adventure.we-accept">{shared.weAccept}</p>
              <ul class="space-y-1 ml-4 mb-3">
                {[shared.euro, shared.usd, shared.egp, shared.gbp].map((item) => (
                  <li class="text-text-secondary">• {item}</li>
                ))}
              </ul>
              <p class="text-text-secondary italic" data-i18n-key="one-week-adventure.card-surcharge">{shared.cardSurcharge}</p>
            </div>

            <div>
              <h3 class="text-xl font-semibold text-primary mb-3" data-i18n-key="one-week-adventure.estimated-costs">{shared.estimatedCosts}</h3>
              <h4 class="font-semibold text-primary mb-2" data-i18n-key="one-week-adventure.included-in-price">{shared.includedInPrice}</h4>
              <ul class="space-y-1 ml-4 mb-4">
                {[shared.airportReception, shared.airportTransfers, shared.fullBoard, shared.diveGuide, shared.divesPerWeek, shared.bottlesWeights, shared.nonAlcoholicDrinks].map((item) => (
                  <li class="flex items-start gap-2 text-text-secondary">
                    <span class="text-accent">✓</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <h4 class="font-semibold text-primary mb-2" data-i18n-key="one-week-adventure.not-included-in-price">{shared.notIncludedInPrice}</h4>
              <ul class="space-y-1 ml-4 mb-4">
                {[shared.visa, shared.environmentalTax, shared.tips, shared.divingEquipment].map((item) => (
                  <li class="flex items-start gap-2 text-text-secondary">
                    <span class="text-red-500">−</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <h4 class="font-semibold text-primary mb-2" data-i18n-key="one-week-adventure.bottle-upgrades">{shared.bottleUpgrades}</h4>
              <ul class="space-y-1 ml-4">
                <li class="text-text-secondary" data-i18n-key="one-week-adventure.bottle-15-aluminum">• {shared.bottle15Aluminum}</li>
                <li class="text-text-secondary" data-i18n-key="one-week-adventure.bottle-15-steel">• {shared.bottle15Steel}</li>
              </ul>
            </div>

            <div>
              <h3 class="text-xl font-semibold text-primary mb-3" data-i18n-key="one-week-adventure.before-boarding">{shared.beforeBoarding}</h3>
              <p class="text-text-secondary mb-3" data-i18n-key="one-week-adventure.before-boarding-intro">{shared.beforeBoardingIntro}</p>
              <ul class="space-y-1 ml-4">
                {[shared.passportCopy, shared.softLuggage, shared.lightClothing, shared.noShoes, shared.lightJacket, shared.powerSupply, shared.mobileInternet, shared.earplugs, shared.waterproofBag, shared.booksMagazines].map((item) => (
                  <li class="flex items-start gap-2 text-text-secondary">
                    <span class="text-accent">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div>
              <h3 class="text-xl font-semibold text-primary mb-3" data-i18n-key="one-week-adventure.required-documents">{shared.requiredDocuments}</h3>
              <ul class="space-y-1 ml-4 mb-4">
                {[shared.originalPassport, shared.diveLogbook, shared.validCertification, shared.bookingVoucher].map((item) => (
                  <li class="flex items-start gap-2 text-text-secondary">
                    <span class="text-accent">✓</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div>
              <h3 class="text-xl font-semibold text-primary mb-3" data-i18n-key="one-week-adventure.medication">{shared.medication}</h3>
              <ul class="space-y-1 ml-4 mb-4">
                {[shared.medicalCertificate, shared.fitnessToDive, shared.declarationResponsibility].map((item) => (
                  <li class="flex items-start gap-2 text-text-secondary">
                    <span class="text-accent">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="bg-secondary/5 rounded-lg p-4 border border-secondary/20">
              <p class="text-text-secondary font-medium" data-i18n-key="one-week-adventure.check-in">{shared.checkIn}</p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </section>
</MainLayout>

<style>
  .formatted-description p {
    margin-bottom: 0.75rem;
    color: #4b5563;
    line-height: 1.75;
  }
  
  .formatted-description strong.highlight-text {
    color: #0c4a6e;
    font-weight: 700;
    background: linear-gradient(180deg, transparent 60%, #dbeafe 60%);
    padding: 0 2px;
  }
  
  .formatted-description em.italic-term {
    font-style: italic;
    color: #0369a1;
    font-weight: 500;
  }
</style>
