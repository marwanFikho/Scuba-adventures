---
import MainLayout from '../../layouts/MainLayout.astro';
import { divingExperiences } from '../../lib/mock-data';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: divingExperiences.map((experience, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: experience.title,
    description: experience.shortDescription
  }))
};
---

<MainLayout title={t.home.featuredTitle} description={t.home.featuredSubtitle}>
  <section class="pt-28 pb-16 bg-background" data-animate="fade-up">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold" data-i18n-key="home.featuredTitle">{t.home.featuredTitle}</h1>
        <p class="text-lg text-text-secondary mt-3" data-i18n-key="home.featuredSubtitle">{t.home.featuredSubtitle}</p>
      </div>
      {divingExperiences.length === 0 && (
        <div class="text-center py-12">
          <p class="text-text-secondary text-lg" data-i18n-key="courses.noCourses">{t.courses.noCourses}</p>
        </div>
      )}
    </div>
  </section>
</MainLayout>

<script type="application/ld+json">
  {JSON.stringify(jsonLd)}
</script>
