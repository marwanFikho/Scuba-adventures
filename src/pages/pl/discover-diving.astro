---
import MainLayout from '../../layouts/MainLayout.astro';
import { getTranslations, getLangFromPathname } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);

const discoverDiving = {
  title: "Odkryj Nurkowanie",
  subtitle: "Doświadczenie 1 Dzień",
  description: `Czy kiedykolwiek zastanawiałeś się, jak to jest oddychać pod wodą jak ryba, czuć się bezwładnie i stać się jednym z pięknem podwodnego świata? To zanurzenie jest dla Ciebie! Pierwsze nurkowanie to najlepszy sposób, aby odkryć to niesamowite doświadczenie przed zobowiązaniem się na kursy takie jak Open Water Diver.

Dołącz do pełnie wykwalifikowanego zespołu podczas tego doświadczenia nurkowego, aby odkryć piękno Morza Czerwonego. Zatrzymaj się w dwóch miejscach nurkowych, naucz się podstaw nurkowania ze sprzętem zapewnionym przez nas, pod okiem profesjonalnych instruktorów, aby odkryć spektakularne rafy koralowe i życie morskie. Pomiędzy dwoma nurkowaniami, ciesz się bufetowym lunchem na łodzi i znajdź czas na relaks przed drugim nurkowaniem. (pływanie i snorkeling są możliwe)

Więcej szczegółów: Samochód lub minivan odbierze Cię z dowolnego hotelu w Hurghadzie między 08:00 a 08:30. (Dla hoteli w Makadi, Sahl Hasheesh i El Gouna czas zostanie przekazany w zależności od lokalizacji hotelu)`,
  itinerary: `Harmonogram Dzienny

Poranny odbiór (8:00-8:30): Komfortowy, klimatyzowany transfer z Twojego hotelu.

Odpłynięcie z mariny (~9:00): Wejdź na pokład łodzi, poznaj swojego przewodnika i ciesz się briefingiem przy herbacie lub kawie.

Pierwsze nurkowanie (~10:00): Nurkuj w jednym z pięknych miejsc Morza Czerwonego.

Przerwa powierzchniowa i lunch: Zrelaksuj się na pokładzie, ciesz się przekąskami i napojami oraz świeżo przygotowanym lunchem w formie bufetu, gdy płyniemy do następnego miejsca.

Drugie nurkowanie (~13:30): Odkryj inny profil rafy, napotykając nowe morskie krajobrazy i życie.

Powrót i drop-off (16:00-17:00): Wróć do mariny, zanim transfer odwiezie Cię do hotelu.`,
  included: "Co jest w cenie",
  includedItems: [
    "Darmowy transfer z wszystkich hoteli w Hurghadzie",
    "Lunch, napoje bezalkoholowe/gorące",
    "Użycie sprzętu do snorkelingu",
    "2 nurkowania",
    "Profesjonalni instruktorzy",
    "Wszystki niezbędny sprzęt nurkowy"
  ],
  excluded: "Nie w cenie",
  excludedItems: [
    "Transfer z El Gouna, Sahl Hasheesh i Makadi Bay: 15€",
    "Wydatki osobiste",
    "Opcjonalna fotografia/filmowanie podwodne"
  ],
  refundPolicy: "Polityka Anulacji i Zwrotu",
  refundIntro: "Chcemy, abyś skupił się na zabawie i przygodzie – nie na płatnościach. Twoja rezerwacja jest bezpieczna.",
  refundItems: [
    "Ponad 24 godziny przed wyjazdem: 100% zwrot",
    "Mniej niż 24 godziny przed wyjazdem: Brak zwrotu",
    "Anulowanie z powodu pogody: Pełny zwrot lub darmowa rezerwacja"
  ],
  whatToBring: "Co zabrać",
  whatToBringItems: [
    "Kopia ważnego paszportu",
    "Oświadczenie lekarskie od lekarza stwierdzające, że jesteś sprawny do nurkowania",
    "Ręcznik i strój kąpielowy",
    "Krem z filtrem i kapelusz",
    "Zmiana ubrań na po nurkowaniu"
  ],
  bookNow: "Zarezerwuj Miejsce",
  priceLabel: "Cena",
  price: "45,00€ za osobę",
  priceNote: "Darmowy transfer z hoteli w Hurghadzie w cenie",
  duration: "1 Dzień (2 nurkowania)"
};
---
<MainLayout title={discoverDiving.title} description={discoverDiving.subtitle}>
  <section class="pt-24 sm:pt-28 pb-12 sm:pb-16 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-16" data-animate="fade-up">
        <h1 class="text-3xl sm:text-5xl font-bold text-primary mb-4" data-i18n-key="discover-diving.title">{discoverDiving.title}</h1>
        <p class="text-base sm:text-xl text-text-secondary max-w-3xl mx-auto" data-i18n-key="discover-diving.subtitle">{discoverDiving.subtitle}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 sm:gap-12 mb-8 sm:mb-16" data-animate="fade-up">
        <div>
          <div class="prose prose-sm max-w-none mb-8">
            {discoverDiving.description.split('\n\n').map((paragraph) => (
              <p class="text-text-secondary mb-4 leading-relaxed">{paragraph}</p>
            ))}
          </div>
        </div>
        <div class="space-y-6">
          <div class="bg-surface border border-gray-200/50 rounded-lg p-4 sm:p-6">
            <h3 class="text-lg sm:text-xl font-bold text-primary mb-4" data-i18n-key="discover-diving.included">{discoverDiving.included}</h3>
            <ul class="space-y-2">
              {discoverDiving.includedItems.map((item) => (
                <li class="flex items-start gap-2 text-text-secondary text-sm">
                  <span class="text-accent font-bold flex-shrink-0">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-surface border border-gray-200/50 rounded-lg p-4 sm:p-6">
            <h3 class="text-lg sm:text-xl font-bold text-primary mb-4" data-i18n-key="discover-diving.excluded">{discoverDiving.excluded}</h3>
            <ul class="space-y-2">
              {discoverDiving.excludedItems.map((item) => (
                <li class="flex items-start gap-2 text-text-secondary text-sm">
                  <span class="text-red-500 font-bold flex-shrink-0">−</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Price -->
        <div class="bg-accent/10 border border-accent/30 rounded-lg p-4 sm:p-6 text-center">
          <h3 class="text-lg sm:text-xl font-bold text-primary mb-1">{discoverDiving.priceLabel}</h3>
          <p class="text-2xl sm:text-3xl font-bold text-accent mb-1">{discoverDiving.price}</p>
          <p class="text-sm text-text-secondary">{discoverDiving.priceNote}</p>
        </div>
      </div>

      <div class="mb-8 sm:mb-16" data-animate="fade-up">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6 text-center" data-i18n-key="discover-diving.daily-schedule">Daily Schedule</h2>
        <div class="max-w-3xl mx-auto">
          {discoverDiving.itinerary.split('\n\n').map((paragraph) => (
            <p class="text-text-secondary mb-3 leading-relaxed">{paragraph}</p>
          ))}
        </div>
      </div>

      <div class="mb-8 sm:mb-16 bg-surface border border-gray-200/50 rounded-lg p-4 sm:p-8" data-animate="fade-up">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6" data-i18n-key="discover-diving.refund-policy">{discoverDiving.refundPolicy}</h2>
        <p class="text-text-secondary mb-4" data-i18n-key="discover-diving.refund-intro">{discoverDiving.refundIntro}</p>
        <ul class="space-y-2 ml-4">
          {discoverDiving.refundItems.map((item) => (
            <li class="flex items-start gap-2 text-text-secondary">
              <span class="text-accent flex-shrink-0">•</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mb-8 sm:mb-16" data-animate="fade-up">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6 text-center" data-i18n-key="discover-diving.what-to-bring">{discoverDiving.whatToBring}</h2>
        <div class="max-w-3xl mx-auto">
          <ul class="space-y-2 ml-4">
            {discoverDiving.whatToBringItems.map((item) => (
              <li class="flex items-start gap-2 text-text-secondary">
                <span class="text-accent flex-shrink-0">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="mb-12 sm:mb-20" data-animate="fade-up">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6 text-center" data-i18n-key="discover-diving.gallery">Co Zobaczyć</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          <img src="/images/discover-diving/Monprojet-13.jpg" alt="Odkryj Nurkowanie - Główny widok" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/1.jpg" alt="Odkryj Nurkowanie - Sprzęt" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/5.jpg" alt="Odkryj Nurkowanie - Podwodny widok" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/2.jpg" alt="Odkryj Nurkowanie - Rafa koralowa" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/3.jpg" alt="Odkryj Nurkowanie - Życie morskie" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/WhatsApp Image 2026-05-22 at 5.20.49 PM.jpeg" alt="Odkryj Nurkowanie - Widok" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/WhatsApp Image 2026-05-22 at 5.20.49 PM (1).jpeg" alt="Odkryj Nurkowanie - Nurkowanie" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/WhatsApp Image 2026-05-22 at 5.20.49 PM (2).jpeg" alt="Odkryj Nurkowanie - Podwodny" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/WhatsApp Image 2026-05-22 at 5.23.53 PM.jpeg" alt="Odkryj Nurkowanie - Morski" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
        </div>
      </div>

      <div class="text-center py-4" data-animate="fade-up">
        <a href={`/${lang}/contact`} class="inline-block bg-secondary text-white px-6 sm:px-8 py-3 sm:py-4 rounded-md font-semibold hover:bg-ocean-muted transition-colors text-base sm:text-lg w-full sm:w-auto" data-i18n-key="discover-diving.book-now">
          {discoverDiving.bookNow}
        </a>
      </div>
    </div>
  </section>
</MainLayout>