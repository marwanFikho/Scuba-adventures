---
import MainLayout from '../../layouts/MainLayout.astro';
import Card from '../../components/ui/Card.astro';
import { lucia } from '../../lib/auth';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);

const { user, session } = await lucia.validateSession(Astro.cookies.get(lucia.sessionCookieName)?.value ?? "");

if (!session) {
    return Astro.redirect(`/${lang}/signin`);
}
---

<MainLayout title={t.dashboard.title} description={t.dashboard.description}>
    <section class="pt-28 pb-16 bg-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-10">
                <div>
                    <h1 class="text-4xl font-bold">{t.dashboard.welcome}, {user.email}</h1>
                    <p class="text-text-secondary mt-2">{t.dashboard.subtitle}</p>
                </div>
                <form method="POST" action="/api/logout">
                    <button type="submit" class="text-red-500 hover:underline">{t.dashboard.logout}</button>
                </form>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <Card>
                    <h2 class="text-2xl font-semibold mb-3">{t.dashboard.upcomingTrips}</h2>
                    <p class="text-text-secondary">{t.dashboard.noTrips}</p>
                </Card>
                <Card>
                    <h2 class="text-2xl font-semibold mb-3">{t.dashboard.purchasedCourses}</h2>
                    <p class="text-text-secondary">{t.dashboard.noCourses}</p>
                </Card>
                <Card>
                    <h2 class="text-2xl font-semibold mb-3">{t.dashboard.paymentHistory}</h2>
                    <p class="text-text-secondary">{t.dashboard.noPayments}</p>
                </Card>
                <Card>
                    <h2 class="text-2xl font-semibold mb-3">{t.dashboard.certifications}</h2>
                    <p class="text-text-secondary">{t.dashboard.noBookings}</p>
                </Card>
            </div>
        </div>
    </section>
</MainLayout>
