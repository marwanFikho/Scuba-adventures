---
import MainLayout from '../../layouts/MainLayout.astro';
import { getTranslations, getLangFromPathname } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);

const discoverDiving = {
  title: "Погружение для начинающих",
  subtitle: "Опыт 1 День",
  description: `Вы когда-нибудь задумывались, каково это дышать под водой как рыба, чувствовать себя невесомым и становиться одним с красотой подводного мира? Тогда это погружение для вас! Первое погружение - лучший способ открыть для себя этот incredible опыт прежде чем приступать к курсам типа Open Water Diver.

Присоединитесь к полностью квалифицированной команде во время этого дайвинг-опыта, чтобы исследовать красоту Красного моря. Остановитесь на двух точках для погружения, изучите основы дайвинга с предоставленным оборудованием, под наблюдением профессиональных инструкторов, чтобы открыть для себя потрясающие кораллы и морскую жизнь. Между двумя погружениями наслаждайтесь фуршетным обедом на лодке и найдите время расслабиться перед вторым погружением. (плавание и снорклинг возможны)

Подробнее: Машину или минивэн заберет вас из любого отеля в Хургаде между 08:00 и 08:30. (Для отелей в Макади, СаХл Хашиш и Эль-Гуна время будет сообщено в зависимости от местоположения отеля)`,
  itinerary: `Ежедневное Расписание

Утренний трансфер (8:00-8:30): Комфортабельный кондиционированный трансфер из вашего отеля.

Отправление из марины (~9:00): Поднимитесь на борт лодки, познакомьтесь с вашим гидом и насладитесь инструктажем за чаем или кофе.

Первое погружение (~10:00): Погрузитесь в одном из прекрасных мест Красного моря.

Перерыв на поверхности и обед: Расслабьтесь на палубе, наслаждайтесь закусками и напитками, а также наслаждайтесь свежеприготовленным буфет-ланчем, пока мы плывем к следующему сайту.

Второе погружение (~13:30): Исследуйте другой профиль рифа, встречая новые морские пейзажи и жизнь.

Возвращение и drop-off (16:00-17:00): Вернитесь в марину, прежде чем трансфер вернет вас в ваш отель.`,
  included: "Что включено",
  includedItems: [
    "Бесплатный трансфер из всех отелей в Хургаде",
    "Обед, безалкогольные/горячие напитки",
    "Использование снаряжения для снорклинга",
    "2 погружения",
    "Профессиональные инструкторы",
    "Все необходимое дайверское оборудование"
  ],
  excluded: "Не включено",
  excludedItems: [
    "Трансфер из Эль-Гуны, СаХл Хашиш и Макади Бэй: 15€",
    "Личные расходы",
    "Опциональная подводная фото/видеосъемка"
  ],
  refundPolicy: "Политика Отмены и Возврата",
  refundIntro: "Мы хотим, чтобы вы сосредоточились на удовольствии и приключении – не на платежах. Ваше бронирование надежно.",
  refundItems: [
    "Более 24 часов до отправления: 100% возврат",
    "Менее 24 часов до отправления: Нет возврата",
    "Отмена из-за погоды: Полный возврат или бесплатное перенос"
  ],
  whatToBring: "Что взять с собой",
  whatToBringItems: [
    "Копия действительного паспорта",
    "Медицинская справка от врача, подтверждающая вашу пригодность для погружения",
    "Полотенце и купальный костюм",
    "Солнцезащитный крем и шляпа",
    "Сменная одежда для после погружения"
  ],
  bookNow: "Забронировать Место",
  price: "45,00€ за человека",
  duration: "1 День (2 погружения)"
};
---
<MainLayout title={discoverDiving.title} description={discoverDiving.subtitle}>
  <section class="pt-24 sm:pt-28 pb-12 sm:pb-16 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-16" data-animate="fade-up">
        <h1 class="text-3xl sm:text-5xl font-bold text-primary mb-4" data-i18n-key="discover-diving.title">{discoverDiving.title}</h1>
        <p class="text-base sm:text-xl text-text-secondary max-w-3xl mx-auto" data-i18n-key="discover-diving.subtitle">{discoverDiving.subtitle}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 sm:gap-12 mb-8 sm:mb-16" data-animate="fade-up">
        <div>
          <div class="prose prose-sm max-w-none mb-8">
            {discoverDiving.description.split('\n\n').map((paragraph) => (
              <p class="text-text-secondary mb-4 leading-relaxed">{paragraph}</p>
            ))}
          </div>
        </div>
        <div class="space-y-6">
          <div class="bg-surface border border-gray-200/50 rounded-lg p-4 sm:p-6">
            <h3 class="text-lg sm:text-xl font-bold text-primary mb-4" data-i18n-key="discover-diving.included">{discoverDiving.included}</h3>
            <ul class="space-y-2">
              {discoverDiving.includedItems.map((item) => (
                <li class="flex items-start gap-2 text-text-secondary text-sm">
                  <span class="text-accent font-bold flex-shrink-0">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-surface border border-gray-200/50 rounded-lg p-4 sm:p-6">
            <h3 class="text-lg sm:text-xl font-bold text-primary mb-4" data-i18n-key="discover-diving.excluded">{discoverDiving.excluded}</h3>
            <ul class="space-y-2">
              {discoverDiving.excludedItems.map((item) => (
                <li class="flex items-start gap-2 text-text-secondary text-sm">
                  <span class="text-red-500 font-bold flex-shrink-0">−</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="mb-8 sm:mb-16" data-animate="fade-up">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6 text-center" data-i18n-key="discover-diving.daily-schedule">Ежедневное Расписание</h2>
        <div class="max-w-3xl mx-auto">
          {discoverDiving.itinerary.split('\n\n').map((paragraph) => (
            <p class="text-text-secondary mb-3 leading-relaxed">{paragraph}</p>
          ))}
        </div>
      </div>

      <div class="mb-8 sm:mb-16 bg-surface border border-gray-200/50 rounded-lg p-4 sm:p-8" data-animate="fade-up">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6" data-i18n-key="discover-diving.refund-policy">{discoverDiving.refundPolicy}</h2>
        <p class="text-text-secondary mb-4" data-i18n-key="discover-diving.refund-intro">{discoverDiving.refundIntro}</p>
        <ul class="space-y-2 ml-4">
          {discoverDiving.refundItems.map((item) => (
            <li class="flex items-start gap-2 text-text-secondary">
              <span class="text-accent flex-shrink-0">•</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mb-8 sm:mb-16" data-animate="fade-up">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6 text-center" data-i18n-key="discover-diving.what-to-bring">{discoverDiving.whatToBring}</h2>
        <div class="max-w-3xl mx-auto">
          <ul class="space-y-2 ml-4">
            {discoverDiving.whatToBringItems.map((item) => (
              <li class="flex items-start gap-2 text-text-secondary">
                <span class="text-accent flex-shrink-0">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="mb-8 sm:mb-16" data-animate="fade-up">
        <div class="flex flex-col items-center">
          <span class="text-text-secondary text-sm mb-2" data-i18n-key="discover-diving.price">{discoverDiving.price}</span>
          <span class="text-text-secondary text-sm" data-i18n-key="discover-diving.duration">{discoverDiving.duration}</span>
        </div>
      </div>

      <div class="mb-12 sm:mb-20" data-animate="fade-up">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6 text-center" data-i18n-key="discover-diving.gallery">Галерея</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          <img src="/images/discover-diving/Monprojet-13.jpg" alt="Погружение для начинающих" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/1.jpg" alt="Погружение для начинающих" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/5.jpg" alt="Погружение для начинающих" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/2.jpg" alt="Погружение для начинающих" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/3.jpg" alt="Погружение для начинающих" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/WhatsApp Image 2026-05-22 at 5.20.49 PM.jpeg" alt="Погружение для начинающих" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/WhatsApp Image 2026-05-22 at 5.20.49 PM (1).jpeg" alt="Погружение для начинающих" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/WhatsApp Image 2026-05-22 at 5.20.49 PM (2).jpeg" alt="Погружение для начинающих" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
          <img src="/images/discover-diving/WhatsApp Image 2026-05-22 at 5.23.53 PM.jpeg" alt="Погружение для начинающих" class="w-full h-48 object-cover rounded-lg shadow-sm" loading="lazy" />
        </div>
      </div>

      <div class="text-center py-4" data-animate="fade-up">
        <a href={`/${lang}/contact`} class="inline-block bg-secondary text-white px-6 sm:px-8 py-3 sm:py-4 rounded-md font-semibold hover:bg-ocean-muted transition-colors text-base sm:text-lg w-full sm:w-auto" data-i18n-key="discover-diving.book-now">
          {discoverDiving.bookNow}
        </a>
      </div>
    </div>
  </section>
</MainLayout>