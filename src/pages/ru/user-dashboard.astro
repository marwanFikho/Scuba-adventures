---
import MainLayout from '../../layouts/MainLayout.astro';
import Card from '../../components/ui/Card.astro';
import { lucia } from '../../lib/auth';
import { getLangFromPathname, getTranslations } from '../../lib/i18n';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);

const { session } = await lucia.validateSession(Astro.cookies.get(lucia.sessionCookieName)?.value ?? "");

if (!session) {
  return Astro.redirect(`/${lang}/signin`);
}
---

<MainLayout title={t.dashboard.title} description={t.dashboard.description}>
  <section class="pt-28 pb-16 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-8">{t.dashboard.welcome}</h1>
      <div class="grid md:grid-cols-2 gap-8">
        <Card>
          <h2 class="text-2xl font-semibold mb-4">{t.dashboard.upcomingTrips}</h2>
          <p class="text-text-secondary">{t.dashboard.noTrips}</p>
        </Card>
        <Card>
          <h2 class="text-2xl font-semibold mb-4">{t.dashboard.purchasedCourses}</h2>
          <p class="text-text-secondary">{t.dashboard.noCourses}</p>
        </Card>
        <Card>
          <h2 class="text-2xl font-semibold mb-4">{t.dashboard.paymentHistory}</h2>
          <p class="text-text-secondary">{t.dashboard.noPayments}</p>
        </Card>
        <Card>
          <h2 class="text-2xl font-semibold mb-4">{t.dashboard.certifications}</h2>
          <p class="text-text-secondary">{t.dashboard.noBookings}</p>
        </Card>
      </div>
    </div>
  </section>
</MainLayout>
