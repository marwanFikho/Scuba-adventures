---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getSpecialtyById } from '../../../lib/course-translations';
import { getLangFromPathname, getTranslations } from '../../../lib/i18n';
import { formatDescription } from '../../../lib/format-description';

const lang = getLangFromPathname(Astro.url.pathname);
const t = getTranslations(lang);

const specialtyId = Astro.params.specialtyId;
const specialty = getSpecialtyById(specialtyId!, lang);

if (!specialty) {
  return Astro.redirect(`/${lang}/specialties`);
}

const dayLabel = specialty.durationDays === 1 ? t.specialties.day : t.specialties.days;
const formattedDescription = formatDescription(specialty.longDescription);
---

<MainLayout title={specialty.title} description={specialty.shortDescription}>
  <section class="pt-28 pb-16 bg-background" data-animate="fade-up">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={`/${lang}/specialties`} class="text-ocean-dark hover:underline mb-8 inline-block font-medium" data-i18n-key="specialties.backToSpecialties">← {t.specialties.backToSpecialties}</a>
      
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="relative h-96 overflow-hidden rounded-xl shadow-premium">
          <img src={specialty.image} alt={specialty.title} class="w-full h-full object-cover" loading="lazy" />
        </div>
        
        <div>
          <h1 class="text-4xl font-bold text-primary mb-4">{specialty.title}</h1>
          
          <div class="bg-surface border border-gray-200/50 rounded-lg p-6 space-y-4 mb-8">
            {specialty.price && (
              <div class="flex items-center justify-between pb-4 border-b border-gray-200">
                <span class="text-text-secondary" data-i18n-key="specialties.price">{t.specialties.price}</span>
                <span class="text-3xl font-bold text-primary">€{specialty.price}</span>
              </div>
            )}
            
            {specialty.durationDays && (
              <div class="flex items-center justify-between pb-4 border-b border-gray-200">
                <span class="text-text-secondary" data-i18n-key="specialties.duration">{t.specialties.duration}</span>
                <span class="font-semibold">{specialty.durationDays} {dayLabel}</span>
              </div>
            )}
            
            {specialty.equipment && (
              <div class="flex items-center justify-between pb-4 border-b border-gray-200">
                <span class="text-text-secondary" data-i18n-key="specialties.equipment">{t.specialties.equipment}</span>
                <span class="font-semibold">{specialty.equipment}</span>
              </div>
            )}
            
            {specialty.requirements && (
              <div class="requirements-row">
                <span class="text-text-secondary requirements-label" data-i18n-key="specialties.requirements">{t.specialties.requirements}</span>
                <span class="requirements-value">{specialty.requirements}</span>
              </div>
            )}
          </div>
          
          <a href={`/${lang}/contact`} class="block w-full bg-secondary text-white py-3 rounded-md font-semibold hover:bg-opacity-90 transition-colors text-center" data-i18n-key="common.bookNow">
            {t.common.bookNow}
          </a>
        </div>
      </div>
      
      <div class="mb-12 formatted-description" set:html={formattedDescription} />
      
      <div class="grid md:grid-cols-2 gap-12 mb-12">
        {specialty.includes && specialty.includes.length > 0 && (
          <div>
            <h3 class="text-xl font-bold text-primary mb-4" data-i18n-key="specialties.includes">{t.specialties.includes}</h3>
            <ul class="space-y-3">
              {specialty.includes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="text-accent mt-1 font-bold">✓</span>
                  <span class="text-text-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        
        {specialty.excludes && specialty.excludes.length > 0 && (
          <div>
            <h3 class="text-xl font-bold text-primary mb-4" data-i18n-key="specialties.excludes">{t.specialties.excludes}</h3>
            <ul class="space-y-3">
              {specialty.excludes.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="text-accent mt-1 font-bold">−</span>
                  <span class="text-text-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .formatted-description {
    max-width: 100%;
  }
  
  .formatted-description h3.description-heading {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0c4a6e;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #0ea5e9;
  }
  
  .formatted-description h3.description-heading:first-child {
    margin-top: 0;
  }
  
  .formatted-description p {
    color: #4b5563;
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }
  
  .formatted-description em.italic-term {
    font-style: italic;
    color: #0369a1;
    font-weight: 500;
  }
  
  .formatted-description strong.highlight-text {
    color: #0c4a6e;
    font-weight: 700;
    background: linear-gradient(180deg, transparent 60%, #dbeafe 60%);
    padding: 0 2px;
  }
  
  .formatted-description ul.description-list {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1rem;
  }
  
  .formatted-description ul.description-list li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
    color: #4b5563;
    line-height: 1.6;
  }
  
  .formatted-description ul.description-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 6px;
    height: 6px;
    background: #0ea5e9;
    border-radius: 50%;
  }
  
  .requirements-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid #e5e7eb;
  }
  
  .requirements-label {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
  }
  
  .requirements-value {
    font-size: 0.95rem;
    color: #374151;
    line-height: 1.6;
  }
</style>
